# ZenTerm Demo Environment
export PS1='\[\e[36m\]demo\[\e[0m\]@\[\e[33m\]zenterm\[\e[0m\]:\[\e[34m\]\w\[\e[0m\]\$ '
export TERM=xterm-256color
alias ll='ls -la --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'

echo ""
echo "  Welcome to ZenTerm Demo"
echo "  Type 'ls' to explore sample files"
echo ""
