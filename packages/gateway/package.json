{
  "name": "zenterm-gateway",
  "version": "0.1.7",
  "description": "Mobile terminal gateway — access your server from any browser or the ZenTerm app",
  "type": "module",
  "bin": {
    "zenterm-gateway": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "public/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "terminal",
    "gateway",
    "ssh",
    "tmux",
    "raspberry-pi",
    "mobile"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.0",
    "fastify-plugin": "^5.1.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@zenterm/shared": "*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
